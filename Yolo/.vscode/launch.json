{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: Uvicorn (Poetry)",
      "type": "debugpy",
      "request": "launch",
      "module": "app.main",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Uvicorn running on (https?://127\\.0\\.0\\.1:8037)",
        "uriFormat": "%s/photolabel"
      }
    },
    {
      "name": "Frontend: Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://127.0.0.1:8037/photolabel",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
